#!/bin/sh

set -eu

max_mb="${LHC_PREPUSH_MAX_MB:-20}"

case "$max_mb" in
  ''|*[!0-9]*)
    echo "pre-push: LHC_PREPUSH_MAX_MB must be an integer" >&2
    exit 1
    ;;
esac

max_bytes=$((max_mb * 1024 * 1024))
tmp_objects="$(git rev-parse --git-path codex-pre-push-objects.$$)"
tmp_sizes="$(git rev-parse --git-path codex-pre-push-sizes.$$)"
trap 'rm -f "$tmp_objects" "$tmp_sizes"' EXIT

while read -r local_ref local_sha remote_ref remote_sha
do
  [ -z "${local_sha:-}" ] && continue

  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    git rev-list --objects "$local_sha" >> "$tmp_objects"
  else
    git rev-list --objects "$local_sha" "^$remote_sha" >> "$tmp_objects"
  fi
done

[ -f "$tmp_objects" ] || exit 0

sort -u "$tmp_objects" | git cat-file --batch-check='%(objectname) %(objecttype) %(objectsize) %(rest)' > "$tmp_sizes"

blocked=0
while read -r object_id object_type object_size object_path
do
  [ "$object_type" = "blob" ] || continue
  [ -n "${object_path:-}" ] || continue

  if [ "$object_size" -gt "$max_bytes" ]; then
    size_mb=$(( (object_size + 1024 * 1024 - 1) / (1024 * 1024) ))
    echo "pre-push: blocked large blob in push: $object_path (${size_mb} MB)" >&2
    blocked=1
  fi
done < "$tmp_sizes"

if [ "$blocked" -ne 0 ]; then
  echo "pre-push: move large datasets under workspace_data/ or store them outside Git history." >&2
  echo "pre-push: override threshold with LHC_PREPUSH_MAX_MB only if the large file is intentionally versioned." >&2
  exit 1
fi

exit 0
