[importlinter]
root_package = app
exclude_type_checking_imports = True

[importlinter:contract:provider-domain-guard]
name = Providers cannot import business domains
type = forbidden
source_modules =
    app.providers
forbidden_modules =
    app.intake
    app.nutrition
    app.budget
    app.body
    app.memory
    app.recommendation
    app.rescue
    app.archive

[importlinter:contract:runtime-shared-business-independence]
name = Runtime and shared should not depend on business domains directly
type = forbidden
source_modules =
    app.runtime
    app.shared
forbidden_modules =
    app.intake
    app.budget
    app.body
    app.memory
    app.recommendation
    app.rescue
    app.archive

[importlinter:contract:later-wave-sidecars-stay-out-of-runtime-platform]
name = Runtime, shared, and providers cannot import offline sidecar packages before activation
type = forbidden
source_modules =
    app.runtime
    app.shared
    app.providers
forbidden_modules =
    app.memory
    app.recommendation
    app.rescue

[importlinter:contract:active-mainline-cannot-import-archive]
name = Active mainline packages must not import archive app families
type = forbidden
source_modules =
    app.runtime
    app.shared
    app.providers
    app.intake
    app.nutrition
    app.budget
    app.body
    app.memory
    app.recommendation
    app.rescue
forbidden_modules =
    app.archive

[importlinter:contract:business-domain-independence]
name = Business domains remain independent by default
type = independence
modules =
    app.intake
    app.nutrition
    app.budget
    app.body
    app.memory
    app.recommendation
    app.rescue
