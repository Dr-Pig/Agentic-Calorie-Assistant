{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "B1Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checkpoint_id",
    "phase",
    "task_id",
    "git_base_sha",
    "git_head_sha",
    "files_changed",
    "tests_run",
    "artifacts",
    "decision_log",
    "rollback_plan",
    "revert_unit",
    "next_safe_action",
    "next_unattended_action_allowed",
    "stop_conditions_checked",
    "architecture_debt_delta",
    "conditions",
    "human_review_required",
    "architecture_boundary_touched"
  ],
  "properties": {
    "checkpoint_id": { "type": "string" },
    "phase": { "type": "string" },
    "task_id": { "type": "string" },
    "git_base_sha": { "type": ["string", "null"] },
    "git_head_sha": { "type": ["string", "null"] },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "result"],
        "properties": {
          "command": { "type": "string" },
          "result": {
            "type": "string",
            "enum": ["pass", "fail", "not_run"]
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "decision_log": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo_truth_used",
          "external_references_used",
          "adopted_guidance",
          "rejected_guidance"
        ],
        "properties": {
          "repo_truth_used": { "type": "string" },
          "external_references_used": {
            "type": "array",
            "items": { "type": "string" }
          },
          "adopted_guidance": { "type": "string" },
          "rejected_guidance": { "type": ["string", "null"] }
        }
      }
    },
    "rollback_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step"],
        "properties": {
          "step": { "type": "string" }
        }
      }
    },
    "revert_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "safe_revert_command", "affected_runtime_behavior"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["commit", "diff_snapshot", "docs_only"]
        },
        "safe_revert_command": { "type": ["string", "null"] },
        "affected_runtime_behavior": { "type": "boolean" }
      }
    },
    "next_safe_action": {
      "type": "string",
      "enum": ["continue", "stop", "human_review"]
    },
    "next_unattended_action_allowed": { "type": "boolean" },
    "stop_conditions_checked": {
      "type": "array",
      "items": { "type": "string" }
    },
    "architecture_debt_delta": {
      "type": "array",
      "items": { "type": "string" }
    },
    "conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "human_review_required": { "type": "boolean" },
    "architecture_boundary_touched": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["product_contract", "runtime_contract", "provider_profile", "retrieval_policy", "eval_only"]
      }
    },
    "preflight_action": { "type": ["string", "null"] }
  }
}
