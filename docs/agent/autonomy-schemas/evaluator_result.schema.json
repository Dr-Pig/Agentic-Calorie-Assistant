{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "B1EvaluatorResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "architecture_rationale",
    "ux_journey_rationale",
    "narrowed_boundary",
    "human_review_required",
    "attack_findings",
    "conditions",
    "approval_rationale",
    "checked_context_packs",
    "architecture_boundary_touched"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "approve_with_conditions", "approve_with_narrower_boundary", "reject"]
    },
    "architecture_rationale": { "type": "string" },
    "ux_journey_rationale": { "type": "string" },
    "narrowed_boundary": {
      "type": ["string", "null"]
    },
    "human_review_required": { "type": "boolean" },
    "attack_findings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must_block", "approve_condition", "cleanup_debt"],
      "properties": {
        "must_block": {
          "type": "array",
          "items": { "type": "string" }
        },
        "approve_condition": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cleanup_debt": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approval_rationale": { "type": "string" },
    "checked_context_packs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "architecture_boundary_touched": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["product_contract", "runtime_contract", "provider_profile", "retrieval_policy", "eval_only"]
      }
    }
  }
}
