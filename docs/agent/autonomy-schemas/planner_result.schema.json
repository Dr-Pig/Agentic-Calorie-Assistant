{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "B1PlannerResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "slice_id",
    "first_blocker",
    "repo_truth_refs",
    "external_refs_checked",
    "external_research_required",
    "external_research_omitted_reason",
    "in_scope_files",
    "out_of_scope",
    "verification_commands",
    "stop_conditions"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "slice_id": { "type": "string" },
    "first_blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "detail"],
      "properties": {
        "code": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "repo_truth_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "external_refs_checked": {
      "type": "array",
      "items": { "type": "string" }
    },
    "external_research_required": { "type": "boolean" },
    "external_research_omitted_reason": {
      "type": ["string", "null"]
    },
    "in_scope_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stop_conditions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
