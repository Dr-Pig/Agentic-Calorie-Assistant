    "can_authorize_mutation": false,
    "can_update_ledger": false
  },
  "response_assertion_policy": {
    "mode": "semantic_facts",
    "must_check": [
      "state posture",
      "estimate or insufficiency honesty",
      "followup presence when required",
      "no false exactness claim",
      "no no-plan remaining or target claim"
    ],
    "must_not_check": [
      "exact wording template",
      "provider-specific phrasing"
    ]
  },
  "deferred_to_v1_8": [
    "browser_ui_shell",
    "delete_void_undo",
    "live_llm_diagnostic",
    "production_db_schema"
