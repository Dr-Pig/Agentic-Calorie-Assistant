{
  "policy_version": 1,
  "active_code": {
    "root": "app",
    "new_active_python_file_default_cap": 220,
    "new_scaffold_shell_default_cap": 80,
    "excluded_globs": [
      "app/**/__pycache__/**",
      "app/**/*.pyc",
      "app/archive/*.py",
      "app/archive/**/*.py"
    ]
  },
  "category_caps": {
    "facade_shim": 120,
    "boundary_surface": 200,
    "adapter_infrastructure": 350,
    "application_orchestration": 320,
    "domain_helper_policy": 260
  },
  "category_rules": [
    {
      "pattern": "app/__init__.py",
      "category": "facade_shim"
    },
    {
      "pattern": "app/**/__init__.py",
      "category": "facade_shim"
    },
    {
      "pattern": "app/routes.py",
      "category": "boundary_surface"
    },
    {
      "pattern": "app/schemas.py",
      "category": "boundary_surface"
    },
    {
      "pattern": "app/models.py",
      "category": "boundary_surface"
    },
    {
      "pattern": "app/main.py",
      "category": "boundary_surface"
    },
    {
      "pattern": "app/database.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/logger.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/logging.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/paths.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/benchmark_loader.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/readiness.py",
      "category": "boundary_surface"
    },
    {
      "pattern": "app/text_integrity.py",
      "category": "domain_helper_policy"
    },
    {
      "pattern": "app/shared/conversation_prompt.py",
      "category": "domain_helper_policy"
    },
    {
      "pattern": "app/shared/time_labels.py",
      "category": "domain_helper_policy"
    },
    {
      "pattern": "app/shared/infra/*.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/shared/infra/**/*.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/**/interface/*.py",
      "category": "boundary_surface"
    },
    {
      "pattern": "app/**/contracts/*.py",
      "category": "boundary_surface"
    },
    {
      "pattern": "app/providers/*.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/**/infrastructure/*.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/**/infrastructure/**/*.py",
      "category": "adapter_infrastructure"
    },
    {
      "pattern": "app/runtime/application/*.py",
      "category": "application_orchestration"
    },
    {
      "pattern": "app/runtime/agent/*.py",
      "category": "application_orchestration"
    },
    {
      "pattern": "app/**/application/*.py",
      "category": "application_orchestration"
    },
    {
      "pattern": "app/**/agent/*.py",
      "category": "domain_helper_policy"
    },
    {
      "pattern": "app/**/domain/*.py",
      "category": "domain_helper_policy"
    }
  ],
  "transition_overrides": {},
  "governance_tooling": {
    "docs": [
      "docs/agent/OVERNIGHT_AUTONOMY_PROTOCOL.md",
      "docs/agent/autonomy-prompts/**",
      "docs/agent/autonomy-schemas/**"
    ],
    "scripts": [
      "scripts/run_b1_cli_autorun.py",
      "scripts/run_codex_exec_with_prompt.py"
    ],
    "tests": [
      "tests/test_b1_cli_autorun.py",
      "tests/test_run_codex_exec_with_prompt.py"
    ]
  },
  "domain_status": {
    "archive": "legacy_archive",
    "body": "active_wave1_implementation",
    "budget": "active_wave1_implementation",
    "intake": "active_wave1_implementation",
    "knowledge": "thin_future_skeleton",
    "nutrition": "active_wave1_implementation",
    "providers": "active_wave1_implementation",
    "runtime": "active_wave1_implementation",
    "shared": "active_wave1_implementation"
  },
  "focus_modules": [
    {
      "path": "app/providers/builderspace_adapter.py",
      "classification": "historical_workaround_residue",
      "recommended_action": "keep_and_deflate",
      "note": "Transport, fallback, parse recovery, diagnostics, and contract validation are currently mixed in one adapter."
    },
    {
      "path": "app/providers/deepseek_adapter.py",
      "classification": "historical_workaround_residue",
      "recommended_action": "keep_and_deflate",
      "note": "Shares the same transport and structured-output seam shape as BuilderSpace, but with less accumulated workaround pressure."
    },
    {
      "path": "app/runtime/agent/manager_branch_contract.py",
      "classification": "wave1_canonical_active",
      "recommended_action": "keep_and_deflate",
      "note": "Wave 1 contract helpers are active, but the file needs schema and validation seams split out."
    },
    {
      "path": "app/shared/infra/canonical_persistence.py",
      "classification": "wave1_canonical_active",
      "recommended_action": "keep_and_deflate",
      "note": "Canonical persistence is active Wave 1 infrastructure, but proposal persistence and serializer helpers need extraction."
    },
    {
      "path": "app/nutrition/agent/nutrition_resolution_normalizer.py",
      "classification": "wave1_canonical_active",
      "recommended_action": "keep_and_deflate",
      "note": "Normalization is Wave 1 canonical, but shaping and policy concerns are mixed in one module."
    },
    {
      "path": "app/archive/rescue/application/proposal.py",
      "classification": "legacy_archive",
      "recommended_action": "archive_hard_keep_out_of_mainline",
      "note": "Pre-V2 rescue proposal synthesis now lives under the archive app family and must stay out of Wave 1 mainline imports."
    },
    {
      "path": "app/archive/rescue/application/runtime.py",
      "classification": "legacy_archive",
      "recommended_action": "archive_hard_keep_out_of_mainline",
      "note": "Pre-V2 rescue runtime persistence is archive-only and must not re-enter Wave 1 runtime ownership."
    },
    {
      "path": "app/archive/rescue/interface/rescue_routes.py",
      "classification": "legacy_archive",
      "recommended_action": "archive_hard_keep_out_of_mainline",
      "note": "Rescue routes live only as archive code and must not regain active router registration."
    },
    {
      "path": "app/archive/recommendation/interface/recommendation_routes.py",
      "classification": "legacy_archive",
      "recommended_action": "archive_hard_keep_out_of_mainline",
      "note": "Recommendation preview and chat code now lives under the archive app family and is excluded from Wave 1 routing."
    },
    {
      "path": "app/archive/memory/infrastructure/conversation_context_retriever.py",
      "classification": "legacy_archive",
      "recommended_action": "archive_hard_keep_out_of_mainline",
      "note": "Conversation retrieval moved under runtime infrastructure; the old memory-domain location now survives only as archive code."
    },
    {
      "path": "app/archive/memory/infrastructure/session_record_store.py",
      "classification": "legacy_archive",
      "recommended_action": "archive_hard_keep_out_of_mainline",
      "note": "Session record storage survives only as archived pre-V2 residue; active runtime support lives under runtime infrastructure."
    }
  ]
}
